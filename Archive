<script>
  // Booking type selector (homepage widget)
  function selectType(el) {
    document.querySelectorAll('.booking-type').forEach(function(b) { b.classList.remove('selected'); });
    el.classList.add('selected');
  }

  // PASSWORD GATE
  if (sessionStorage.getItem('hch_auth') === 'true') {
    document.addEventListener('DOMContentLoaded', function() {
      var gate = document.getElementById('passwordGate');
      if (gate) gate.style.display = 'none';
    });
  }

  function checkPassword() {
    var val = document.getElementById('gateInput').value.toLowerCase().trim();
    if (val === 'coco') {
      sessionStorage.setItem('hch_auth', 'true');
      var gate = document.getElementById('passwordGate');
      gate.style.transition = 'opacity 0.5s ease';
      gate.style.opacity = '0';
      setTimeout(function() { gate.style.display = 'none'; }, 500);
    } else {
      document.getElementById('gateError').style.display = 'block';
      document.getElementById('gateInput').value = '';
      document.getElementById('gateInput').focus();
    }
  }

  // MODAL SYSTEM
  function openModal(id) {
    var el = document.getElementById(id);
    el.style.display = 'flex';
    requestAnimationFrame(function() { el.classList.add('open'); });
    document.body.style.overflow = 'hidden';
  }

  function closeModal(id) {
    var el = document.getElementById(id);
    el.classList.remove('open');
    setTimeout(function() { el.style.display = 'none'; }, 300);
    document.body.style.overflow = '';
  }

  function closeModalOutside(e, id) {
    if (e.target.id === id) closeModal(id);
  }

  function switchModal(from, to) {
    closeModal(from);
    setTimeout(function() { openModal(to); }, 320);
  }

  // Booking steps
  function bookingNext(step) {
    [1,2,3].forEach(function(i) {
      var stepEl = document.getElementById('bookStep' + i);
      var dotEl = document.getElementById('bStep' + i);
      if (stepEl) stepEl.style.display = (i === step) ? 'block' : 'none';
      if (dotEl) dotEl.classList.toggle('active', i <= step);
    });
  }

  function selectModalType(el) {
    document.querySelectorAll('.modal-type-pill').forEach(function(p) { p.classList.remove('selected'); });
    el.classList.add('selected');
  }

  function showLoginSuccess() {
    var body = document.querySelector('#modalLogin .modal-body');
    body.innerHTML = '<div class="modal-success">'
      + '<div class="success-icon" style="background:rgba(201,168,76,0.12);border-color:rgba(201,168,76,0.3);">&#10003;</div>'
      + '<div class="success-title" style="color:var(--cream)">Welcome Back</div>'
      + '<p class="success-desc">Redirecting you to your course library and digital content...</p>'
      + '<button class="btn-modal-submit" onclick="closeModal(&quot;modalLogin&quot;)">Done</button>'
      + '</div>';
  }

  // Close modals on Escape
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      document.querySelectorAll('.modal-overlay.open').forEach(function(m) { closeModal(m.id); });
    }
  });

  // MOBILE MENU
  function toggleMenu() {
    var menu = document.getElementById('mobileMenu');
    var hamburger = document.getElementById('hamburger');
    var isOpen = menu.classList.contains('open');
    if (isOpen) {
      menu.classList.remove('open');
      hamburger.classList.remove('open');
      document.body.style.overflow = '';
    } else {
      menu.classList.add('open');
      hamburger.classList.add('open');
      document.body.style.overflow = 'hidden';
    }
  }

  function closeMenu() {
    document.getElementById('mobileMenu').classList.remove('open');
    document.getElementById('hamburger').classList.remove('open');
    document.body.style.overflow = '';
  }
</script>
