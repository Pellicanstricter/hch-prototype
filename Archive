<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hahnemann Center for Heilkunst & Homeopathy</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --green-deep: #1a2e1e;
    --green-mid: #2d4a32;
    --green-light: #4a7a52;
    --cream: #f5f0e8;
    --cream-dark: #ede5d4;
    --gold: #c9a84c;
    --gold-light: #e0c47a;
    --text-dark: #1a1a18;
    --text-mid: #4a4a42;
    --text-light: #8a8a7a;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Jost', sans-serif;
    background: var(--cream);
    color: var(--text-dark);
    overflow-x: hidden;
  }

  /* NAV */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 3rem;
    background: rgba(26, 46, 30, 0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(201, 168, 76, 0.2);
  }

  .nav-logo {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .nav-logo-main {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--cream);
    letter-spacing: 0.05em;
    line-height: 1;
  }

  .nav-logo-sub {
    font-size: 0.65rem;
    font-weight: 300;
    color: var(--gold);
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    list-style: none;
    align-items: center;
  }

  .nav-links a {
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.75);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--gold-light); }

  .nav-cta {
    background: var(--gold) !important;
    color: var(--green-deep) !important;
    padding: 0.6rem 1.4rem;
    border-radius: 2px;
    font-weight: 500 !important;
    transition: background 0.2s !important;
  }

  .nav-cta:hover { background: var(--gold-light) !important; }

  /* HERO */
  .hero {
    min-height: 100vh;
    background: var(--green-deep);
    display: grid;
    grid-template-columns: 1fr 1fr;
    position: relative;
    overflow: hidden;
  }

  .hero-texture {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(ellipse at 20% 50%, rgba(74, 122, 82, 0.15) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 20%, rgba(201, 168, 76, 0.08) 0%, transparent 50%);
  }

  /* botanical SVG background */
  .hero-botanical {
    position: absolute;
    right: -60px;
    top: 50%;
    transform: translateY(-50%);
    width: 55%;
    opacity: 0.06;
    pointer-events: none;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 8rem 4rem 6rem 5rem;
    position: relative;
    z-index: 2;
  }

  .hero-eyebrow {
    font-size: 0.68rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .hero-eyebrow::before {
    content: '';
    display: block;
    width: 32px;
    height: 1px;
    background: var(--gold);
  }

  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3rem, 5vw, 4.5rem);
    font-weight: 300;
    line-height: 1.1;
    color: var(--cream);
    margin-bottom: 1.75rem;
  }

  .hero-title em {
    font-style: italic;
    color: var(--gold-light);
  }

  .hero-desc {
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.75;
    color: rgba(245, 240, 232, 0.65);
    max-width: 420px;
    margin-bottom: 3rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .btn-primary {
    background: var(--gold);
    color: var(--green-deep);
    padding: 0.9rem 2.2rem;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    transition: background 0.25s, transform 0.2s;
    display: inline-block;
  }

  .btn-primary:hover {
    background: var(--gold-light);
    transform: translateY(-1px);
  }

  .btn-ghost {
    color: rgba(245, 240, 232, 0.7);
    font-size: 0.78rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.9rem 1.5rem;
    border: 1px solid rgba(245, 240, 232, 0.2);
    border-radius: 2px;
    transition: border-color 0.2s, color 0.2s;
  }

  .btn-ghost:hover {
    border-color: var(--gold);
    color: var(--gold-light);
  }

  .hero-stats {
    margin-top: 4rem;
    display: flex;
    gap: 3rem;
    padding-top: 2.5rem;
    border-top: 1px solid rgba(245, 240, 232, 0.1);
  }

  .stat-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    font-weight: 300;
    color: var(--gold-light);
    line-height: 1;
    margin-bottom: 0.3rem;
  }

  .stat-label {
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.4);
  }

  .hero-right {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }

  .hero-image-frame {
    position: relative;
    width: 75%;
    aspect-ratio: 3/4;
    border-radius: 2px;
    overflow: hidden;
  }

  .hero-image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #2d4a32 0%, #1a3520 40%, #0f2312 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }

  /* botanical illustration SVG inline */
  .botanical-icon {
    width: 120px;
    height: 160px;
    opacity: 0.4;
  }

  .hero-image-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2rem;
    background: linear-gradient(transparent, rgba(15, 35, 18, 0.95));
  }

  .hero-image-caption-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.9rem;
    font-style: italic;
    color: rgba(245, 240, 232, 0.6);
    letter-spacing: 0.03em;
  }

  .hero-corner-ornament {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 60px;
    height: 60px;
    border-top: 1px solid var(--gold);
    border-right: 1px solid var(--gold);
    opacity: 0.4;
  }

  /* TWO PATHS SECTION */
  .paths {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 60vh;
  }

  .path-card {
    padding: 5rem 4.5rem;
    position: relative;
    overflow: hidden;
    cursor: pointer;
    transition: background 0.4s;
  }

  .path-card:first-child {
    background: var(--cream-dark);
    border-right: 1px solid rgba(26, 46, 30, 0.1);
  }

  .path-card:last-child {
    background: var(--green-mid);
  }

  .path-card:first-child:hover { background: #e8dfc9; }
  .path-card:last-child:hover { background: #355a3a; }

  .path-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: 6rem;
    font-weight: 300;
    line-height: 1;
    margin-bottom: 1.5rem;
    opacity: 0.12;
    position: absolute;
    top: 2rem;
    right: 3rem;
  }

  .path-card:first-child .path-number { color: var(--green-deep); }
  .path-card:last-child .path-number { color: var(--cream); }

  .path-icon {
    width: 48px;
    height: 48px;
    margin-bottom: 1.75rem;
  }

  .path-label {
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .path-card:first-child .path-label { color: var(--gold); }
  .path-card:last-child .path-label { color: var(--gold-light); }

  .path-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.5rem;
    font-weight: 400;
    line-height: 1.15;
    margin-bottom: 1.25rem;
  }

  .path-card:first-child .path-title { color: var(--green-deep); }
  .path-card:last-child .path-title { color: var(--cream); }

  .path-desc {
    font-size: 0.9rem;
    font-weight: 300;
    line-height: 1.75;
    margin-bottom: 2.5rem;
    max-width: 340px;
  }

  .path-card:first-child .path-desc { color: var(--text-mid); }
  .path-card:last-child .path-desc { color: rgba(245, 240, 232, 0.65); }

  .path-link {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    transition: gap 0.2s;
  }

  .path-link:hover { gap: 1.2rem; }
  .path-card:first-child .path-link { color: var(--green-deep); }
  .path-card:last-child .path-link { color: var(--gold-light); }

  .path-link::after {
    content: '→';
    font-size: 1rem;
  }

  /* PHILOSOPHY STRIP */
  .philosophy {
    background: var(--gold);
    padding: 2rem 5rem;
    display: flex;
    align-items: center;
    gap: 3rem;
    overflow: hidden;
  }

  .philosophy-quote {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.4rem;
    font-style: italic;
    font-weight: 300;
    color: var(--green-deep);
    line-height: 1.4;
    flex: 1;
  }

  .philosophy-attr {
    font-size: 0.68rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(26, 46, 30, 0.55);
    white-space: nowrap;
  }

  /* CONSULTATION CTA */
  .consult-section {
    padding: 7rem 5rem;
    background: var(--cream);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .consult-left .section-eyebrow {
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .consult-left .section-eyebrow::before {
    content: '';
    display: block;
    width: 24px;
    height: 1px;
    background: var(--gold);
  }

  .consult-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.8rem;
    font-weight: 300;
    line-height: 1.2;
    color: var(--green-deep);
    margin-bottom: 1.5rem;
  }

  .consult-desc {
    font-size: 0.95rem;
    font-weight: 300;
    line-height: 1.8;
    color: var(--text-mid);
    margin-bottom: 2.5rem;
  }

  .process-steps {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .process-step {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .step-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem;
    font-weight: 300;
    color: var(--gold);
    line-height: 1;
    min-width: 2rem;
  }

  .step-content h4 {
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--green-deep);
    margin-bottom: 0.3rem;
  }

  .step-content p {
    font-size: 0.82rem;
    font-weight: 300;
    color: var(--text-light);
    line-height: 1.6;
  }

  /* BOOKING CARD */
  .booking-card {
    background: var(--green-deep);
    border-radius: 4px;
    padding: 3rem;
    position: relative;
    overflow: hidden;
  }

  .booking-card::before {
    content: '';
    position: absolute;
    top: -40px;
    right: -40px;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: rgba(201, 168, 76, 0.06);
  }

  .booking-card-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem;
    font-weight: 300;
    color: var(--cream);
    margin-bottom: 0.5rem;
  }

  .booking-card-sub {
    font-size: 0.78rem;
    color: rgba(245, 240, 232, 0.45);
    letter-spacing: 0.08em;
    margin-bottom: 2rem;
  }

  .booking-type {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(201, 168, 76, 0.2);
    border-radius: 3px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1rem;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .booking-type:hover {
    border-color: var(--gold);
    background: rgba(201, 168, 76, 0.05);
  }

  .booking-type.selected {
    border-color: var(--gold);
    background: rgba(201, 168, 76, 0.08);
  }

  .booking-type-name {
    font-size: 0.88rem;
    color: var(--cream);
    font-weight: 400;
  }

  .booking-type-detail {
    font-size: 0.72rem;
    color: rgba(245, 240, 232, 0.4);
    margin-top: 0.2rem;
  }

  .booking-type-price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2rem;
    color: var(--gold-light);
  }

  .booking-divider {
    height: 1px;
    background: rgba(255,255,255,0.07);
    margin: 1.5rem 0;
  }

  .booking-availability {
    font-size: 0.72rem;
    color: rgba(245, 240, 232, 0.35);
    letter-spacing: 0.08em;
    margin-bottom: 1.5rem;
  }

  .availability-days {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .day-pill {
    font-size: 0.65rem;
    padding: 0.3rem 0.7rem;
    border-radius: 20px;
    letter-spacing: 0.08em;
  }

  .day-pill.active {
    background: rgba(201, 168, 76, 0.15);
    color: var(--gold-light);
    border: 1px solid rgba(201, 168, 76, 0.3);
  }

  .day-pill.inactive {
    background: rgba(255,255,255,0.04);
    color: rgba(245, 240, 232, 0.2);
    border: 1px solid rgba(255,255,255,0.06);
  }

  .btn-book {
    width: 100%;
    background: var(--gold);
    color: var(--green-deep);
    border: none;
    padding: 1rem;
    font-family: 'Jost', sans-serif;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    border-radius: 2px;
    transition: background 0.2s;
    margin-top: 0.5rem;
  }

  .btn-book:hover { background: var(--gold-light); }

  /* TESTIMONIALS */
  .testimonials {
    background: var(--green-deep);
    padding: 6rem 5rem;
  }

  .testimonials-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-eyebrow-light {
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
  }

  .section-title-light {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.5rem;
    font-weight: 300;
    color: var(--cream);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .testimonial-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 3px;
    padding: 2rem;
    transition: border-color 0.2s;
  }

  .testimonial-card:hover { border-color: rgba(201, 168, 76, 0.3); }

  .testimonial-stars {
    color: var(--gold);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .testimonial-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.05rem;
    font-style: italic;
    font-weight: 300;
    color: rgba(245, 240, 232, 0.8);
    line-height: 1.65;
    margin-bottom: 1.5rem;
  }

  .testimonial-author {
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .testimonial-location {
    font-size: 0.68rem;
    color: rgba(245, 240, 232, 0.3);
    margin-top: 0.2rem;
  }

  /* FOOTER */
  footer {
    background: #111a12;
    padding: 4rem 5rem 2rem;
    border-top: 1px solid rgba(201, 168, 76, 0.15);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .footer-brand-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2rem;
    color: var(--cream);
    margin-bottom: 0.4rem;
  }

  .footer-brand-sub {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
  }

  .footer-desc {
    font-size: 0.82rem;
    font-weight: 300;
    color: rgba(245, 240, 232, 0.35);
    line-height: 1.7;
    max-width: 280px;
  }

  .footer-col-title {
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.25rem;
  }

  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .footer-links a {
    font-size: 0.82rem;
    font-weight: 300;
    color: rgba(245, 240, 232, 0.45);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-links a:hover { color: var(--cream); }

  .footer-bottom {
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.06);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-copyright {
    font-size: 0.72rem;
    color: rgba(245, 240, 232, 0.25);
    letter-spacing: 0.05em;
  }

  /* ANIMATIONS */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-eyebrow { animation: fadeUp 0.7s ease both; }
  .hero-title { animation: fadeUp 0.7s ease 0.15s both; }
  .hero-desc { animation: fadeUp 0.7s ease 0.25s both; }
  .hero-actions { animation: fadeUp 0.7s ease 0.35s both; }
  .hero-stats { animation: fadeUp 0.7s ease 0.45s both; }
  .hero-right { animation: fadeUp 0.9s ease 0.3s both; }

  /* HAMBURGER */
  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 4px;
    background: none;
    border: none;
    z-index: 200;
  }

  .nav-hamburger span {
    display: block;
    width: 24px;
    height: 1.5px;
    background: var(--cream);
    transition: all 0.3s ease;
    transform-origin: center;
  }

  .nav-hamburger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .nav-hamburger.open span:nth-child(2) { opacity: 0; }
  .nav-hamburger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  /* MOBILE MENU OVERLAY */
  .mobile-menu {
    display: none;
    position: fixed;
    inset: 0;
    background: var(--green-deep);
    z-index: 150;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2.5rem;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .mobile-menu.open {
    opacity: 1;
  }

  .mobile-menu a {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    font-weight: 300;
    color: var(--cream);
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: color 0.2s;
  }

  .mobile-menu a:hover { color: var(--gold-light); }

  .mobile-menu .mobile-cta {
    background: var(--gold);
    color: var(--green-deep) !important;
    font-family: 'Jost', sans-serif;
    font-size: 0.8rem !important;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 1rem 2.5rem;
    border-radius: 2px;
    margin-top: 1rem;
  }

  /* ================================
     RESPONSIVE BREAKPOINTS
  ================================ */

  @media (max-width: 900px) {
    /* NAV */
